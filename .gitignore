# ============================================================
# .gitignore
# ============================================================

# Virtual environment
venv/
env/
.venv/

# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# Jupyter
.ipynb_checkpoints/
*.ipynb_checkpoints

# Data — full candidate pool is too large for GitHub (487 MB)
# sample/ is committed (small, needed for sandbox)
data/candidates.jsonl
data/candidates.jsonl.gz

# Outputs — regenerated by rank.py; don't commit intermediate runs
outputs/

# OS files
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/

# ============================================================
# NOT ignored (intentionally committed):
# artifacts/embeddings.npy        (~73 MB float16)
# artifacts/features.parquet      (~few MB)
# artifacts/jd_embedding.npy      (<1 KB)
# data/sample/                    (50-100 candidates for sandbox)
# scripts/jd_config.json          (structured JD requirements)
# ============================================================
